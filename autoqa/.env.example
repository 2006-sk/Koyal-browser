# Target site (or pass --url on the command line)
AUTOQA_URL=https://beta.koyal.ai

# Credentials (optional — the CLI prompts on first run and can save them per-site;
# KOYAL_TEST_EMAIL/PASSWORD from ../login/.env are also picked up automatically)
# AUTOQA_EMAIL=
# AUTOQA_PASSWORD=

# LLM (falls back to ../login/.env)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# LLM_MAX_STEPS_PER_GOAL=12

# Browser
# AGENT_BROWSER_HEADED=true
# AGENT_SHOW_CURSOR=true

# Crawl caps
# AUTOQA_MAX_PAGES=25
# AUTOQA_CRAWL_DEPTH=4
# AUTOQA_PROBES_PER_PAGE=6

# Hard cap on LLM calls per run (0 = unlimited)
# AUTOQA_LLM_BUDGET=0

# Comma-separated file paths suggested for uploads
# AUTOQA_UPLOAD_SUGGESTIONS=/path/to/test.pdf,/path/to/test.wav
