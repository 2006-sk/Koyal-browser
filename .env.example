# Base URL for the beta app under test
KOYAL_BASE_URL=https://beta.koyal.ai

# New account for signup flow — must be an email not already registered
KOYAL_SIGNUP_EMAIL=
KOYAL_SIGNUP_NAME=QA Test User
KOYAL_SIGNUP_PASSWORD=KoyalQa!Signup2026

# Demo / test account credentials (never commit real values)
KOYAL_TEST_EMAIL=
KOYAL_TEST_PASSWORD=

# Optional: separate account for forgot-password flow
KOYAL_RESET_EMAIL=

# agent-browser session names (isolated browser contexts)
KOYAL_SESSION_AUTH=qa-auth
KOYAL_SESSION_APP=qa-app

# Browser visibility
AGENT_BROWSER_HEADED=true
AGENT_SHOW_CURSOR=true
AGENT_ACTION_DELAY_MS=350

# LLM exploration layer — fallback only when deterministic selectors fail
LLM_ENABLED=true
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_MAX_STEPS_PER_GOAL=8

# Provider hints:
#   openai     -> https://api.openai.com/v1
#   anthropic  -> https://api.anthropic.com/v1  (set LLM_MODEL e.g. claude-sonnet-4-20250514)
#   openrouter -> https://openrouter.ai/api/v1
#   custom     -> set LLM_BASE_URL to your OpenAI-compatible endpoint
