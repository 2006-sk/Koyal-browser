{
  "name": "koyal-qa-agent",
  "version": "0.1.0",
  "description": "Phase 1 automated QA agent for beta.koyal.ai auth flow and app shell",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "qa:login": "tsx src/run-login.ts",
    "qa": "tsx src/run.ts",
    "qa:forgot": "tsx src/run.ts --forgot-only",
    "qa:signup": "tsx src/run.ts --signup-only",
    "discover": "tsx src/discover.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "agent-browser": "^0.31.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
