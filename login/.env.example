# Base URL for the beta app under test
KOYAL_BASE_URL=https://beta.koyal.ai

# New account for signup flow — must be an email not already registered
KOYAL_SIGNUP_EMAIL=
KOYAL_SIGNUP_NAME=QA Test User
KOYAL_SIGNUP_PASSWORD=KoyalQa!Signup2026

# Demo / test account credentials (never commit real values)
KOYAL_TEST_EMAIL=
KOYAL_TEST_PASSWORD=

# Optional: separate account for forgot-password flow
KOYAL_RESET_EMAIL=

# OTP / reset codes — write to file while the runner waits (or set env vars to skip file wait)
#   Signup OTP:     login/.state/signup-otp.txt   (or KOYAL_SIGNUP_OTP=123456)
#   Reset code:     login/.state/reset-code.txt   (or KOYAL_RESET_CODE=...)
KOYAL_CODE_WAIT_MS=60000
KOYAL_CODE_POLL_MS=2000
# KOYAL_CODE_PROMPT_INTERACTIVE=true  # paste in terminal instead of file

# agent-browser session names (isolated browser contexts)
KOYAL_SESSION_AUTH=qa-auth
KOYAL_SESSION_APP=qa-app

# Browser visibility
AGENT_BROWSER_HEADED=true
AGENT_SHOW_CURSOR=true
AGENT_ACTION_DELAY_MS=350

# LLM exploration layer — fallback only when deterministic selectors fail
LLM_ENABLED=true
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_STEPS_PER_GOAL=8

# Provider hints:
#   anthropic  -> ANTHROPIC_API_KEY (default) — https://api.anthropic.com/v1
#   openai     -> OPENAI_API_KEY or LLM_API_KEY — https://api.openai.com/v1
#   openrouter -> LLM_API_KEY — https://openrouter.ai/api/v1
#   custom     -> LLM_API_KEY + LLM_BASE_URL (OpenAI-compatible endpoint)
