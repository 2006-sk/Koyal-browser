{
  "name": "koyal-qa-audio",
  "version": "0.1.0",
  "description": "Agentic E2E QA for Koyal audio upload happy flow",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "qa": "tsx src/run.ts --full-only",
    "qa:all": "tsx src/run.ts",
    "qa:full": "tsx src/run.ts --full-only",
    "qa:e2e": "tsx src/run.ts --e2e-only",
    "qa:mp3": "tsx src/run.ts --mp3-only",
    "qa:back-forth": "tsx src/run.ts --back-forth-only",
    "qa:wizard-nav": "tsx src/run.ts --wizard-nav-only",
    "qa:quick": "tsx src/run.ts --e2e-only --skip-mp3 --skip-back-forth --skip-wizard-nav"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "agent-browser": "^0.31.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
