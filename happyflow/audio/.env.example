# Inherits login/.env when present; copy this to .env for audio-only overrides.

KOYAL_BASE_URL=https://beta.koyal.ai
KOYAL_TEST_EMAIL=
KOYAL_TEST_PASSWORD=

# agent-browser session for audio QA (single session per full run)
KOYAL_SESSION_AUDIO=qa-audio

AGENT_BROWSER_HEADED=true
AGENT_SHOW_CURSOR=true
AGENT_ACTION_DELAY_MS=350

# Verification timeouts (audio processing is slow)
VERIFICATION_MAX_WAIT_MS=15000
VERIFICATION_POLL_MS=1000
AUDIO_TRANSCRIPT_WAIT_MS=120000
AUDIO_SCENE_WAIT_MS=180000
AUDIO_FINAL_WAIT_MS=180000

# Default test audio (paths relative to happyflow/audio/)
KOYAL_AUDIO_WAV=assets/test-narration-alt.wav
KOYAL_AUDIO_MP3=assets/test-narration-alt.mp3
KOYAL_AUDIO_SHORT_WAV=assets/test-narration-short.wav
KOYAL_AUDIO_SHORT_MP3=assets/test-narration-short.mp3

# Reuse login auth state when available
KOYAL_LOGIN_STATE_PATH=../../login/.state/qa-auth.json
